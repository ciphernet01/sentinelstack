# Host-run (non-Docker) backend/prisma settings
# Use this when running Prisma CLI or the backend directly on Windows (not inside a container).
DATABASE_URL=postgresql://user:password@localhost:5432/sentinelstack?schema=public

# For managed Postgres (Neon/Supabase):
# - DATABASE_URL can be the pooled/transaction URL for app runtime
# - DIRECT_URL should be the direct connection string used for migrations
DIRECT_URL=
PORT=3001
CLIENT_URL=http://localhost:3000

# Backend container environment (.env.backend)
# This file is loaded by docker-compose for the backend service.
# NEVER commit the real .env.backend (it contains secrets).

# App
PORT=3001
CLIENT_URL=http://localhost:3000

# DEV ONLY: allow the authenticated /api/assessments/reset endpoint even if NODE_ENV=production
# (useful when running the backend in Docker while iterating on onboarding)
# ENABLE_DEV_RESET=true

# Admin bypass for scan limits (comma-separated emails). Accounts listed here can scan even if usage is exhausted.
# Example:
# ADMIN_EMAILS=admin@sentinel-stack.tech,ss9415767850@gmail.com
ADMIN_EMAILS=

# Database (inside Docker network)
DATABASE_URL=postgresql://user:password@sentinel-postgres:5432/sentinelstack?schema=public

# Optional: direct DB URL for Prisma migrations (recommended for Neon/Supabase)
DIRECT_URL=

# AI
GEMINI_API_KEY=CHANGE_ME

# Internal-only secret used to allow the backend PDF generator (Puppeteer) to render
# server-side report pages without being redirected to /login.
PDF_RENDER_SECRET=CHANGE_ME

# Firebase Admin credentials (choose one approach)
# Preferred: path to a JSON stored outside the repo (recommended for prod)
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\\path\\to\\service-account.json

# Or split env vars:
FIREBASE_PROJECT_ID=CHANGE_ME
FIREBASE_CLIENT_EMAIL=CHANGE_ME
FIREBASE_PRIVATE_KEY=CHANGE_ME

# Email Configuration
EMAIL_SERVICE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=CHANGE_ME
EMAIL_FROM_NAME=SentinelStack Security

# Billing
# Choose billing provider: stripe | razorpay
BILLING_PROVIDER=razorpay

# Stripe (if BILLING_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TAX_ENABLED=false
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=

# Razorpay (if BILLING_PROVIDER=razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

RAZORPAY_PRO_INR_MONTHLY_PLAN_ID=
RAZORPAY_PRO_INR_YEARLY_PLAN_ID=
RAZORPAY_ENTERPRISE_INR_MONTHLY_PLAN_ID=
RAZORPAY_ENTERPRISE_INR_YEARLY_PLAN_ID=
RAZORPAY_PRO_USD_MONTHLY_PLAN_ID=
RAZORPAY_PRO_USD_YEARLY_PLAN_ID=
RAZORPAY_ENTERPRISE_USD_MONTHLY_PLAN_ID=
RAZORPAY_ENTERPRISE_USD_YEARLY_PLAN_ID=

# Optional default currency for billing (INR|USD)
BILLING_DEFAULT_CURRENCY=INR

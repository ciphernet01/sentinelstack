{
  "name": "sentinel-stack-app",
  "version": "1.0.0",
  "description": "Sentinel Stack Enterprise Application Security Intelligence Platform",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "render-build": "npm install && npm run build:frontend",
    "prisma:generate:host": "node scripts/run-with-env.js --env .env.host -- npx prisma generate",
    "prisma:migrate:host": "node scripts/run-with-env.js --env .env.host -- npx prisma migrate dev",
    "prisma:deploy:host": "node scripts/run-with-env.js --env .env.host -- npx prisma migrate deploy",
    "prisma:studio:host": "node scripts/run-with-env.js --env .env.host -- npx prisma studio",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "nodemon src/server.ts",
    "build:backend": "tsc -p tsconfig.backend.json",
    "start:backend": "node dist/server.js",
    "dev:frontend": "next dev",
    "frontend": "npm run dev:frontend",
    "build:frontend": "next build",
    "start:frontend": "next start",
    "start:frontend:render": "next start -p $PORT",
    "build": "npm-run-all build:backend build:frontend",
    "start": "concurrently \"npm:start:backend\" \"npm:start:frontend\"",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "security:secrets": "node scripts/security/check-secrets.js",
    "security:precommit": "node scripts/security/check-staged-env.js && node scripts/security/check-secrets.js",
    "prepare": "node scripts/husky-install.js",
    "hooks:install": "node scripts/husky-install.js",
    "admin:grant-scans": "node scripts/admin/grant-scans.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@genkit-ai/google-genai": "^1.27.0",
    "@hookform/resolvers": "^3.6.0",
    "@prisma/client": "^5.14.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.45.0",
    "@types/nodemailer": "^7.0.4",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "embla-carousel-react": "^8.1.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.1.0",
    "file-saver": "^2.0.5",
    "firebase": "^10.12.2",
    "firebase-admin": "^12.1.0",
    "genkit": "^1.27.0",
    "helmet": "^7.1.0",
    "lucide-react": "^0.390.0",
    "morgan": "^1.10.0",
    "next": "^14.2.35",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.12",
    "prisma": "^5.14.0",
    "puppeteer": "^22.9.0",
    "react": "^18",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18",
    "react-hook-form": "^7.51.5",
    "recharts": "^2.12.7",
    "resend": "^0.10.0",
    "sharp": "^0.34.5",
    "stripe": "^20.3.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.16.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "husky": "^9.0.11",
    "nodemon": "^3.1.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "winston": "^3.13.0"
  },
  "overrides": {
    "@firebase/auth": {
      "undici": "6.23.0"
    },
    "@firebase/auth-compat": {
      "undici": "6.23.0"
    },
    "@firebase/firestore": {
      "undici": "6.23.0"
    },
    "@firebase/functions": {
      "undici": "6.23.0"
    },
    "@firebase/storage": {
      "undici": "6.23.0"
    },
    "resend": {
      "axios": "1.13.4"
    }
  }
}

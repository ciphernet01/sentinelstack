# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sentinelstack?schema=public"

# Optional: direct DB URL for Prisma migrations (recommended for Neon/Supabase)
DIRECT_URL=""

# Server
PORT=3001
CLIENT_URL="http://localhost:3000"

# AI / LLM
GEMINI_API_KEY=""

# Internal-only secret used to allow backend PDF rendering to fetch authenticated pages
PDF_RENDER_SECRET=""

# Firebase Admin SDK - Credentials from your service account
# Ensure the private key is properly formatted in a single line (e.g., replace newlines with \n)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Firebase Client (Next.js) - public config values
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Email (choose one provider)
EMAIL_SERVICE=smtp
EMAIL_FROM=""
EMAIL_FROM_NAME="SentinelStack"

# SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASSWORD=""

# SendGrid (optional)
SENDGRID_API_KEY=""
